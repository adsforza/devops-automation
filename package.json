{
  "name": "f1-telemetry-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm --prefix server run dev",
    "dev:web": "npm --prefix web run dev",
    "build": "npm --prefix server run build && npm --prefix web run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
